# Docker commands
docker pull postgres
docker run --name blog-postgres -e POSTGRES_USER=postgres -e POSTGRES_PASSWORD=1234 -e POSTGRES_DB=blogdb -p 5432:5432 -d postgres
docker ps
docker stop blog-postgres
docker start blog-postgres

docker exec -it blog-postgres psql -U postgres -d blogdb



# Spring Boot backend commands
cd backend-project-folder
mvn clean install
mvn spring-boot:run

# Angular frontend commands
npm install @angular/cli
npx ng new my-app        # if not created yet
cd my-app
npm install
npm install baseline-browser-mapping@latest --save-dev
npx ng serve





src/main/java/com/
├── config/       ← Spring configs & initializers
├── controller/   ← REST endpoints (AuthController)
├── entity/       ← User, Post, Comment entities
├── repository/   ← JpaRepository interfaces
├── service/      ← AuthService, PostService (business logic)
├── security/     ← JwtUtil, JwtFilter, etc.
├── util/         ← Response class, helper classes

